{
  "name": "splitease-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply splitease --remote",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260701.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  }
}
